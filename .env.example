# Required for the keeper bot (bot.ts)
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Privy App ID.
# Optional for local/testnet flows; required for mainnet/prod.
# NEXT_PUBLIC_PRIVY_APP_ID=cmlqkgtmg00og0cjueu4mxmn9

# Private server settings only:
# Local SQLite database file path.
# Defaults to data/lore.sqlite if omitted.
# LORE_DB_PATH=/var/lib/lore/lore.sqlite
#
# Optional private RPC key/provider endpoint
# KEEPER_RPC_URL=https://your-private-rpc.example
#
# Network selection:
# Keep omitted for Sepolia dev, set BOTH vars for mainnet/prod.
# LINEA_NETWORK=mainnet
# NEXT_PUBLIC_LINEA_NETWORK=mainnet
#
# Contract deployment settings:
# Set BOTH frontend and server contract address vars when you deploy a new contract.
# Leave NEXT_PUBLIC_CONTRACT_HAS_TOKEN_GETTER=0 only if you intentionally point at the old legacy Sepolia deployment.
# For the current Sepolia deployment and V6/mainnet deployments, set it to 1 (or omit it for non-legacy addresses).
# KEEPER_CONTRACT_ADDRESS=0xYourContractAddress
# NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress
# NEXT_PUBLIC_LINEA_TOKEN_ADDRESS=0xYourLineaTokenAddress
# INDEXER_START_BLOCK=1234567
# NEXT_PUBLIC_CONTRACT_DEPLOY_BLOCK=1234567
# NEXT_PUBLIC_LINEA_RPCS=https://rpc.linea.build,https://your-backup-rpc.example
# NEXT_PUBLIC_CONTRACT_HAS_TOKEN_GETTER=1
# NEXT_PUBLIC_CONTRACT_HAS_REBATE_API=1
#
# Optional private app URL override
# NEXT_PUBLIC_SITE_URL=https://playlore.xyz
#
# Required in production if chat auth is enabled.
# CHAT_AUTH_SECRET=replace-with-a-long-random-secret
#
# Optional private diagnostic secret for full /api/health/data-sync payloads outside localhost.
# HEALTH_DIAGNOSTICS_SECRET=replace-with-a-long-random-secret
#
# Optional maintenance toggle
# NEXT_PUBLIC_MAINTENANCE_MODE=0

# Optional gas-saving toggles (frontend):
# Keep both OFF by default to avoid extra resolve tx gas from browser users.
# NEXT_PUBLIC_ENABLE_CLIENT_AUTO_RESOLVE=0
# NEXT_PUBLIC_ENABLE_AUTO_RESOLVE_SWEEP=0

# Optional Telegram alerts for keeper (server-side only, never exposed to frontend)
# ALERT_TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_BOT_TOKEN
# ALERT_TELEGRAM_CHAT_ID=-1001234567890
# ALERT_TELEGRAM_THREAD_ID=12345
# ALERT_PREFIX=LORE Keeper
# ALERT_COOLDOWN_MS=300000
