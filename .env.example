# Required for the keeper bot (bot.ts)
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Firebase Realtime Database (used by API /api/deposits, /api/epochs, /api/jackpots and by indexer)
# If unset, default is https://lore-78751-default-rtdb.europe-west1.firebasedatabase.app
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.region.firebasedatabase.app
# Optional: auth token for indexer writes when RTDB rules require auth
# FIREBASE_DB_AUTH=

# Show maintenance overlay (1 or true to enable)
# NEXT_PUBLIC_MAINTENANCE_MODE=0

# Optional overrides
# KEEPER_CONTRACT_ADDRESS=0x0b0b5894dd370a6ca053a6979e95bd252a41e6a4
# KEEPER_RPC_URL=https://rpc.sepolia.linea.build
# Optional: force full backfill start block for indexer repair mode
# INDEXER_START_BLOCK=25663555
# Optional: epoch reconcile tuning (safe defaults)
# INDEXER_RECONCILE_INTERVAL_MS=120000
# INDEXER_RECONCILE_MAX_EPOCHS_PER_PASS=8

# Optional Telegram alerts for keeper (server-side only, never exposed to frontend)
# ALERT_TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_BOT_TOKEN
# ALERT_TELEGRAM_CHAT_ID=-1001234567890
# ALERT_TELEGRAM_THREAD_ID=12345
# ALERT_PREFIX=LORE Keeper
# ALERT_COOLDOWN_MS=300000
