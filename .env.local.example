# Firebase Realtime Database config for chat
# Create a project at https://console.firebase.google.com
# Enable Realtime Database, copy config from Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Realtime Database secret/token for server-side writes.
# Paste the value from Firebase -> Realtime Database -> Secrets for your RTDB instance.
# Example: FIREBASE_DB_AUTH=your_rtdb_secret_here
FIREBASE_DB_AUTH=

# Network selection
# LINEA_NETWORK=mainnet
# NEXT_PUBLIC_LINEA_NETWORK=mainnet

# Frontend contract deployment settings
# NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourContractAddress
# NEXT_PUBLIC_LINEA_TOKEN_ADDRESS=0xYourLineaTokenAddress
# NEXT_PUBLIC_CONTRACT_DEPLOY_BLOCK=1234567
# NEXT_PUBLIC_LINEA_RPCS=https://rpc.linea.build,https://your-backup-rpc.example
# NEXT_PUBLIC_CONTRACT_HAS_TOKEN_GETTER=1
# NEXT_PUBLIC_CONTRACT_HAS_REBATE_API=1

# Optional Telegram alerts for keeper/supervisor (server-side only)
# ALERT_TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_BOT_TOKEN
# ALERT_TELEGRAM_CHAT_ID=-1001234567890
# ALERT_TELEGRAM_THREAD_ID=
# ALERT_PREFIX=LORE Keeper
# ALERT_COOLDOWN_MS=3000000
