{
  "rules": {
    "messages": {
      ".read": true,
      ".indexOn": ["timestamp"],
      "$messageId": {
        ".write": false
      }
    },
    "gamedata": {
      ".read": true,
      ".write": false,
      "bets": {
        "$user": {
          ".indexOn": ["epoch"]
        }
      },
      "jackpots": {
        ".indexOn": ["epoch"]
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
